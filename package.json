{
  "name": "opencode-mcp",
  "version": "1.0.0",
  "description": "MCP server for integrating AI-powered IDEs with OpenCode agents. Supports multi-agent delegation, auto-start, and resilient connections.",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "author": "Jinto AG",
  "license": "MIT",
  "keywords": [
    "mcp",
    "mcp-server",
    "opencode",
    "agent",
    "ai",
    "swarm",
    "claude",
    "cursor"
  ],
  "scripts": {
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --compile --outfile opencode-mcp",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@types/bun": "latest",
    "axios-mock-adapter": "^2.1.0",
    "husky": "^9.1.7"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@opencode-ai/sdk": "^1.2.21",
    "axios": "^1.13.6",
    "axios-retry": "^4.5.0",
    "dotenv": "^17.3.1"
  }
}
