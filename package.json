{
  "name": "opencode-mcp",
  "version": "1.2.1",
  "description": "MCP server for integrating AI-powered IDEs with OpenCode agents. Supports multi-agent delegation, auto-start, and resilient connections.",
  "module": "src/index.ts",
  "type": "module",
  "bin": {
    "opencode-mcp": "./src/index.ts"
  },
  "author": "Jinto AG",
  "license": "MIT",
  "keywords": [
    "mcp",
    "mcp-server",
    "opencode",
    "agent",
    "ai",
    "swarm",
    "claude",
    "cursor"
  ],
  "scripts": {
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --compile --outfile opencode-mcp",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@types/bun": "latest",
    "@types/lodash-es": "^4.17.12",
    "bun-types": "^1.3.10",
    "husky": "^9.1.7",
    "msw": "^2.12.10",
    "nanoid": "^5.1.6"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@opencode-ai/sdk": "^1.2.21",
    "dotenv": "^17.3.1",
    "execa": "^9.6.1",
    "lodash-es": "^4.17.23"
  }
}
